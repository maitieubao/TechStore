@using TechStore.Shared.DTOs
@model ProductDto

<div class="card h-100 border-0 bg-darker rounded-4 shadow-sm hover-shadow-lg transition-all product-card overflow-hidden group">
    <!-- Wishlist Button -->
    <a href="#" class="btn btn-dark btn-sm rounded-circle position-absolute top-0 end-0 m-3 z-3 shadow-sm wishlist-btn d-flex align-items-center justify-content-center border-secondary bg-opacity-75" style="width: 32px; height: 32px; backdrop-filter: blur(4px);"
       data-id="@Model.Id" 
       data-auth="@User.Identity?.IsAuthenticated.ToString().ToLower()" title="Thêm vào yêu thích">
       <i class="bi bi-heart text-danger"></i>
    </a>

    <a asp-controller="Product" asp-action="Detail" asp-route-slug="@Model.Slug" class="text-decoration-none">
        <div class="position-relative overflow-hidden product-img-wrap bg-white d-flex align-items-center justify-content-center p-3" style="aspect-ratio: 1/1;">
            @if (Model.StockQuantity <= 0)
            {
                <span class="badge bg-danger position-absolute top-0 start-0 m-3 z-2 rounded-pill px-3 py-2 shadow-sm">Hết hàng</span>
            }
            <product-img src="@Model.ImageUrls.FirstOrDefault()" alt="@Model.Name" class="img-fluid object-fit-contain transition-transform group-hover-scale" style="max-height: 100%;" />
        </div>
    </a>
    <div class="card-body d-flex flex-column p-4">
        <small class="text-primary fw-semibold mb-2 text-truncate" style="font-size: 0.8rem; letter-spacing: 0.5px;">@Model.CategoryName?.ToUpper()</small>
        <a asp-controller="Product" asp-action="Detail" asp-route-slug="@Model.Slug" class="text-decoration-none text-white d-block mb-3">
            <h6 class="card-title text-truncate fw-bold hover-primary transition-colors" title="@Model.Name">
                @Model.Name
            </h6>
        </a>
        <div class="mt-auto">
            <div class="d-flex align-items-center gap-2 mb-1">
                <span class="text-price fs-5 fw-bold text-warning">@Model.Price.ToString("N0") ₫</span>
                @if (Model.IsCombo && Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
                {
                    <span class="text-secondary text-decoration-line-through small">@Model.OriginalPrice.Value.ToString("N0") ₫</span>
                }
            </div>
            <div class="d-flex justify-content-between align-items-center pt-2 border-top border-secondary border-opacity-25">
                <div class="d-flex align-items-center gap-1">
                    @if (Model.IsCombo)
                    {
                        <span class="badge bg-warning text-dark small rounded-pill px-2 py-1"><i class="bi bi-gift"></i> COMBO</span>
                    }
                    else if (Model.StockQuantity <= 5 && Model.StockQuantity > 0)
                    {
                        <span class="badge bg-danger bg-opacity-75 small fw-normal">Sắp hết hàng</span>
                    }
                </div>
                @if (Model.StockQuantity > 0)
                {
                    <form asp-area="User" asp-controller="Cart" asp-action="Add" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-gradient rounded-circle d-flex align-items-center justify-content-center shadow-sm hover-lift" style="width: 40px; height: 40px;" title="Thêm vào giỏ">
                            <i class="bi bi-cart-plus fs-5"></i>
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
