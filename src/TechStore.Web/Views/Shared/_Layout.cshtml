@inject TechStore.Web.Services.Interfaces.IWishlistApiService WishlistService
<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>
    <meta name="description" content="TechStore - Cửa hàng công nghệ hàng đầu Việt Nam" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        try
        {
            var wishlist = await WishlistService.GetWishlistAsync();
            var wishlistIds = wishlist?.Select(w => w.ProductId).ToList() ?? new List<int>();
            <script>window.userWishlist = @Json.Serialize(wishlistIds);</script>
        }
        catch
        {
            <script>window.userWishlist = [];</script>
        }
    }
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg sticky-top border-bottom" style="background: rgba(15,17,23,0.9); backdrop-filter: blur(16px);">
        <div class="container">
            @if (User.IsInRole("Admin"))
            {
                <a class="navbar-brand fw-bold fs-4 text-gradient" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill"></i> TechStore Admin
                </a>
            }
            else
            {
                <a class="navbar-brand fw-bold fs-4 text-gradient" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill"></i> TechStore
                </a>
            }
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <!-- Search -->
                <form class="d-flex mx-auto" style="max-width: 400px; width: 100%;" asp-area="" asp-controller="Product" asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="search" class="form-control" placeholder="Tìm kiếm sản phẩm..." 
                               value="@Context.Request.Query["search"]" />
                        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-grid"></i> Sản phẩm
                        </a>
                    </li>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Wishlist" asp-action="Index" title="Danh sách yêu thích">
                                <i class="bi bi-heart fs-5"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-area="User" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3 fs-5"></i>
                                @await Component.InvokeAsync("CartWidget")
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-area="User" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-lines-fill me-2"></i>Hồ sơ của tôi</a></li>
                                <li><a class="dropdown-item" asp-area="User" asp-controller="Order" asp-action="History"><i class="bi bi-bag-check me-2"></i>Đơn hàng</a></li>
                                <li><a class="dropdown-item" asp-area="User" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart me-2"></i>Yêu thích</a></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Quản trị</a></li>
                                }
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-gradient btn-sm px-3" asp-area="" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-person"></i> Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- TOAST NOTIFICATIONS -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-fixed">
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center py-2 px-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close btn-close-white ms-3" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-fixed">
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center py-2 px-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close btn-close-white ms-3" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <!-- MAIN -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="border-top mt-5 py-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold text-gradient"><i class="bi bi-lightning-charge-fill"></i> TechStore</h5>
                    <p class="text-secondary small">Cửa hàng công nghệ hàng đầu Việt Nam. Cam kết sản phẩm chính hãng, bảo hành uy tín.</p>
                </div>
                <div class="col-lg-2">
                    <h6 class="fw-semibold">Liên kết</h6>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-1"><a asp-area="" asp-controller="Home" asp-action="About">Về chúng tôi</a></li>
                        <li class="mb-1"><a asp-area="" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="mb-1"><a asp-area="" asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-semibold">Hỗ trợ</h6>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-1"><a href="#">Chính sách bảo hành</a></li>
                        <li class="mb-1"><a href="#">Chính sách đổi trả</a></li>
                        <li class="mb-1"><a href="#">Hướng dẫn mua hàng</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-semibold">Liên hệ</h6>
                    <p class="text-secondary small mb-1"><i class="bi bi-geo-alt me-1"></i> 123 Nguyễn Huệ, Q1, TP.HCM</p>
                    <p class="text-secondary small mb-1"><i class="bi bi-telephone me-1"></i> 1900 1234</p>
                    <p class="text-secondary small"><i class="bi bi-envelope me-1"></i> support@techstore.vn</p>
                </div>
            </div>
            <hr />
            <p class="text-center text-secondary small mb-0">&copy; 2026 TechStore. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
