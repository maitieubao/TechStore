@model TechStore.Web.Models.ViewModels.ProductListVM
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="container py-4">
    <div class="row">
        <!-- FILTER SIDEBAR -->
        <div class="col-lg-3 mb-4">
            <form asp-controller="Product" asp-action="Index" method="get" class="card border-0 bg-darker rounded-4 shadow-sm filter-panel position-sticky" style="top: 100px;">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-white mb-4"><i class="bi bi-funnel-fill text-primary me-2"></i>Bộ lọc</h5>

                    <!-- Search -->
                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Tìm kiếm</label>
                        <input type="text" name="search" class="form-control bg-dark border-secondary text-white rounded-3 shadow-none" placeholder="Tên sản phẩm..."
                               value="@Model.Filter.Search" />
                    </div>

                    <!-- Category -->
                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Danh mục</label>
                        <select name="categoryId" class="form-select bg-dark border-secondary text-white rounded-3 shadow-none">
                            <option value="">Tất cả danh mục</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(Model.Filter.CategoryId == cat.Id)">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Brand -->
                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Thương hiệu</label>
                        <select name="brand" class="form-select bg-dark border-secondary text-white rounded-3 shadow-none">
                            <option value="">Tất cả thương hiệu</option>
                            @foreach (var brand in Model.Brands)
                            {
                                <option value="@brand" selected="@(Model.Filter.Brand == brand)">@brand</option>
                            }
                        </select>
                    </div>

                    <!-- Price -->
                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Khoảng giá (₫)</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="number" name="minPrice" class="form-control bg-dark border-secondary text-white rounded-3 shadow-none" placeholder="Từ"
                                       value="@Model.Filter.MinPrice" />
                            </div>
                            <div class="col-6">
                                <input type="number" name="maxPrice" class="form-control bg-dark border-secondary text-white rounded-3 shadow-none" placeholder="Đến"
                                       value="@Model.Filter.MaxPrice" />
                            </div>
                        </div>
                    </div>

                    <!-- Sort -->
                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Sắp xếp theo</label>
                        <select name="sortBy" class="form-select bg-dark border-secondary text-white rounded-3 shadow-none mb-3">
                            <option value="" selected="@(string.IsNullOrEmpty(Model.Filter.SortBy))">Mặc định</option>
                            <option value="price" selected="@(Model.Filter.SortBy == "price")">Giá</option>
                            <option value="name" selected="@(Model.Filter.SortBy == "name")">Tên sản phẩm</option>
                            <option value="createdAt" selected="@(Model.Filter.SortBy == "createdAt")">Mới nhất</option>
                        </select>
                        
                        <div class="d-flex align-items-center justify-content-between p-3 bg-dark rounded-3 border border-secondary">
                            <label class="form-check-label small text-white" for="sortDescCheck">Thứ tự giảm dần</label>
                            <div class="form-check form-switch m-0 d-flex align-items-center">
                                <input class="form-check-input mt-0" type="checkbox" role="switch" name="sortDescending" value="true" id="sortDescCheck"
                                       checked="@Model.Filter.SortDescending" style="cursor: pointer;" />
                            </div>
                        </div>
                    </div>

                    <!-- In stock -->
                    <div class="mb-4">
                        <div class="d-flex align-items-center justify-content-between p-3 bg-dark rounded-3 border border-secondary">
                            <label class="form-check-label small text-white" for="inStockCheck">Chỉ hiện còn hàng</label>
                            <div class="form-check form-switch m-0 d-flex align-items-center">
                                <input class="form-check-input mt-0" type="checkbox" role="switch" name="inStock" value="true" id="inStockCheck"
                                       checked="@(Model.Filter.InStock == true)" style="cursor: pointer;" />
                            </div>
                        </div>
                    </div>

                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@Model.Filter.PageSize" />

                    <button type="submit" class="btn btn-gradient btn-lg w-100 rounded-pill fw-bold shadow">
                        <i class="bi bi-funnel"></i> Áp dụng bộ lọc
                    </button>
                    
                    @if (!string.IsNullOrEmpty(Model.Filter.Search) || Model.Filter.CategoryId.HasValue || !string.IsNullOrEmpty(Model.Filter.Brand) || Model.Filter.MinPrice.HasValue || Model.Filter.MaxPrice.HasValue)
                    {
                        <div class="mt-3 text-center">
                            <a asp-action="Index" class="text-secondary small text-decoration-none hover-primary"><i class="bi bi-x-circle me-1"></i>Xóa bộ lọc</a>
                        </div>
                    }
                </div>
            </form>
        </div>

        <!-- PRODUCT GRID -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4 bg-darker p-3 rounded-4 shadow-sm">
                <p class="text-secondary mb-0">
                    Tìm thấy <strong class="text-white fs-5 mx-1">@Model.Products.TotalCount</strong> <span class="d-none d-sm-inline">sản phẩm phù hợp</span>
                </p>
            </div>

            @if (Model.Products.Items?.Any() ?? false)
            {
                <div class="row g-3">
                    @foreach (var product in Model.Products.Items)
                    {
                        <div class="col-6 col-md-4">
                            @await Html.PartialAsync("_ProductCard", product)
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.Products.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= Model.Products.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Filter.Page ? "active" : "")">
                                    <a class="page-link"
                                       asp-controller="Product" asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@Model.Filter.PageSize"
                                       asp-route-search="@Model.Filter.Search"
                                       asp-route-categoryId="@Model.Filter.CategoryId"
                                       asp-route-brand="@Model.Filter.Brand"
                                       asp-route-minPrice="@Model.Filter.MinPrice"
                                       asp-route-maxPrice="@Model.Filter.MaxPrice"
                                       asp-route-sortBy="@Model.Filter.SortBy"
                                       asp-route-sortDescending="@Model.Filter.SortDescending"
                                       asp-route-inStock="@Model.Filter.InStock">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5 text-secondary">
                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                    <h5>Không tìm thấy sản phẩm</h5>
                    <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
                </div>
            }
        </div>
    </div>
</div>
