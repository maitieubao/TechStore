@model TechStore.Web.Models.ViewModels.VerifyOtpVM
@{
    ViewData["Title"] = "Xác thực OTP";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card border-0 bg-darker rounded-4 shadow-lg overflow-hidden position-relative group">
                <!-- Background decorative blob -->
                <div class="position-absolute top-0 start-0 w-100 h-100 text-info opacity-10 pointer-events-none" style="background: radial-gradient(circle at top right, currentColor 0%, transparent 60%);"></div>

                <div class="card-body p-4 p-md-5 position-relative z-1">
                    <div class="text-center mb-4">
                        <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center border border-secondary mb-3 shadow" style="width: 65px; height: 65px;">
                            <i class="bi bi-shield-lock-fill text-info fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-white mb-2">Xác Thực Email</h4>
                        <p class="text-secondary small">Vui lòng nhập mã OTP gồm 6 chữ số đã được gửi tới email <strong>@Model.Email</strong></p>
                    </div>

                    <div asp-validation-summary="All" class="alert alert-danger bg-danger-subtle text-danger border-0 small py-2 rounded-3" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <form asp-action="VerifyOtp" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Email" value="@Model.Email" />

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-secondary">Mã OTP</label>
                            <input type="text" name="Otp" class="form-control bg-dark text-white border-secondary focus-ring-primary py-2 text-center fs-4 letter-spacing-1" placeholder="------" maxlength="6"
                                   required autocomplete="off" />
                            <span asp-validation-for="Otp" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-gradient w-100 mb-3 py-2 rounded-pill shadow-sm hover-lift fw-medium">
                            <i class="bi bi-check-circle me-2"></i> Xác thực & Đăng ký
                        </button>
                    </form>

                    <p class="text-center text-secondary small mb-0">
                        Chưa nhận được mã? <a href="#" class="text-info fw-semibold text-decoration-none" onclick="history.back();">Đăng ký lại</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
