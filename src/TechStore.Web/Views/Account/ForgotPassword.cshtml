@model TechStore.Web.Models.ViewModels.ForgotPasswordVM
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card border-0 bg-darker rounded-4 shadow-lg overflow-hidden position-relative group">
                <!-- Background decorative blob -->
                <div class="position-absolute top-0 start-0 w-100 h-100 text-info opacity-10 pointer-events-none" style="background: radial-gradient(circle at top right, currentColor 0%, transparent 60%);"></div>

                <div class="card-body p-4 p-md-5 position-relative z-1">
                    <div class="text-center mb-4">
                        <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center border border-secondary mb-3 shadow" style="width: 65px; height: 65px;">
                            <i class="bi bi-key-fill text-info fs-3"></i>
                        </div>
                        <h4 class="fw-bold text-white mb-2">Quản lý mật khẩu</h4>
                        <p class="text-secondary small">Nhập email đăng ký của bạn để nhận mã OTP khôi phục tài khoản</p>
                    </div>

                    <div asp-validation-summary="All" class="alert alert-danger bg-danger-subtle text-danger border-0 small py-2 rounded-3" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-secondary">Email của bạn</label>
                            <input type="email" name="Email" class="form-control bg-dark text-white border-secondary focus-ring-primary py-2" placeholder="email@example.com"
                                   required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-gradient w-100 mb-3 py-2 rounded-pill shadow-sm hover-lift fw-medium">
                            <i class="bi bi-envelope-paper me-2"></i> Nhận mã OTP
                        </button>
                    </form>

                    <p class="text-center text-secondary small mb-0">
                        Quay lại trang <a asp-action="Login" class="text-info fw-semibold text-decoration-none">Đăng nhập</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
