@model TechStore.Web.Models.ViewModels.HomeVM
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- HOME WRAPPER FOR DARK MODE -->
<div class="bg-dark text-white">

<!-- HERO -->
<section class="hero-section py-5 position-relative overflow-hidden" style="background: radial-gradient(circle at top right, #1a1e29 0%, #0d1117 100%);">
    <!-- Decorative elements -->
    <div class="position-absolute top-0 end-0 translate-middle-y rounded-circle bg-primary opacity-25" style="width: 400px; height: 400px; filter: blur(100px);"></div>
    <div class="position-absolute bottom-0 start-0 translate-middle text-info opacity-10" style="width: 300px; height: 300px; filter: blur(80px); border-radius: 50%;"></div>
    
    <div class="container position-relative z-1">
        <div class="row align-items-center py-4">
            <div class="col-lg-7">
                <span class="badge bg-darker border border-secondary text-primary rounded-pill px-3 py-2 mb-3 shadow-sm" style="font-size: 0.9rem;">
                    <i class="bi bi-stars me-1 text-warning"></i>Kỷ Nguyên Công Nghệ Mới
                </span>
                <h1 class="display-4 fw-bold mb-3" style="line-height: 1.2;">
                    Công nghệ <span class="text-gradient">đỉnh cao</span><br />
                    cho cuộc sống hiện đại
                </h1>
                <p class="lead text-secondary mt-3 mb-4" style="max-width: 500px;">
                    Laptop, điện thoại, phụ kiện chính hãng — Giá tốt nhất thị trường, giao hàng cực tốc tại TP.HCM
                </p>
                <div class="d-flex gap-3 mt-4">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-gradient btn-lg rounded-pill px-4 shadow">
                        <i class="bi bi-bag-fill me-2"></i> Mua sắm ngay
                    </a>
                    <a asp-controller="Home" asp-action="About" class="btn btn-outline-light btn-lg rounded-pill px-4" style="backdrop-filter: blur(4px);">
                        <i class="bi bi-info-circle me-2"></i> Tìm hiểu thêm
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center position-relative">
                <div class="position-relative d-inline-block">
                    <!-- Glassmorphism decorative card -->
                    <div class="position-absolute top-50 start-50 translate-middle bg-white bg-opacity-10 border border-white border-opacity-25 rounded-circle shadow-lg" style="width: 320px; height: 320px; backdrop-filter: blur(10px);"></div>
                    <i class="bi bi-laptop position-relative z-2 text-white" style="font-size: 14rem; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.5));"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORIES -->
@if (Model.Categories.Any())
{
    <section class="py-5">
        <div class="container py-3">
            <div class="text-center mb-5">
                <h2 class="fw-bold mb-2">Khám Phá Danh Mục</h2>
                <p class="text-secondary">Trải nghiệm các thiết bị công nghệ hàng đầu thế giới</p>
            </div>
            <div class="row g-4">
                @{
                    var icons = new[] { "bi-laptop", "bi-phone", "bi-tablet", "bi-headphones", "bi-keyboard", "bi-mouse", "bi-display", "bi-cpu" };
                }
                @foreach (var (cat, idx) in Model.Categories.Select((c, i) => (c, i)))
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                            <div class="card bg-darker border-0 rounded-4 text-center p-4 h-100 hover-shadow-lg hover-lift transition-all group">
                                <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center border border-secondary group-hover-border-primary transition-colors" style="width: 80px; height: 80px;">
                                    <div class="text-gradient fs-1"><i class="bi @icons[idx % icons.Length]"></i></div>
                                </div>
                                <h6 class="fw-bold text-white mt-3 mb-0">@cat.Name</h6>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- FEATURED PRODUCTS -->
@if (Model.FeaturedProducts.Any())
{
    <section class="py-5" style="background-color: #0b0f19;">
        <div class="container py-3">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold mb-2"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Sản Phẩm Nổi Bật</h2>
                    <p class="text-secondary mb-0">Thiết bị được yêu thích và săn đón nhiều nhất</p>
                </div>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill d-none d-sm-inline-flex px-4">
                    Xem tất cả <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
            <div class="row g-4">
                @foreach (var product in Model.FeaturedProducts)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
            <div class="mt-4 text-center d-block d-sm-none">
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100">
                    Xem tất cả <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </section>
}

<!-- NEW ARRIVALS -->
@if (Model.NewArrivals.Any())
{
    <section class="py-5">
        <div class="container py-3">
            <div class="text-center mb-5">
                <h2 class="fw-bold mb-2"><i class="bi bi-stars text-primary me-2"></i>Hàng Mới Về</h2>
                <p class="text-secondary">Siêu phẩm công nghệ vừa hạ cánh tại TechStore</p>
            </div>
            <div class="row g-4">
                @foreach (var product in Model.NewArrivals)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- WHY US -->
<section class="py-5 position-relative overflow-hidden" style="background-color: #0b0f19;">
    <!-- Abstract gradient blob -->
    <div class="position-absolute top-50 start-50 translate-middle rounded-circle bg-primary opacity-10" style="width: 600px; height: 600px; filter: blur(120px);"></div>
    
    <div class="container py-4 position-relative z-1">
        <div class="text-center mb-5">
            <span class="badge bg-dark border border-secondary text-info rounded-pill px-3 py-2 mb-2 shadow-sm">Dịch vụ hàng đầu</span>
            <h2 class="fw-bold">Tại sao chọn TechStore?</h2>
            <p class="text-secondary">Trải nghiệm mua sắm công nghệ an toàn, nhanh chóng và tận tâm</p>
        </div>
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="card bg-darker border-0 rounded-4 text-center p-4 h-100 shadow-sm hover-lift transition-transform">
                    <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3 shadow" style="width: 70px; height: 70px;">
                        <div class="text-gradient fs-2"><i class="bi bi-shield-check"></i></div>
                    </div>
                    <h6 class="fw-bold text-white mt-2">Chính Hãng 100%</h6>
                    <small class="text-secondary">Cam kết sản phẩm Auth, bảo hành toàn quốc</small>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card bg-darker border-0 rounded-4 text-center p-4 h-100 shadow-sm hover-lift transition-transform">
                    <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3 shadow" style="width: 70px; height: 70px;">
                        <div class="text-gradient fs-2"><i class="bi bi-truck"></i></div>
                    </div>
                    <h6 class="fw-bold text-white mt-2">Giao Hàng Siêu Tốc</h6>
                    <small class="text-secondary">Giao nhận nhanh chóng 2h khu vực TP.HCM</small>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card bg-darker border-0 rounded-4 text-center p-4 h-100 shadow-sm hover-lift transition-transform">
                    <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3 shadow" style="width: 70px; height: 70px;">
                        <div class="text-gradient fs-2"><i class="bi bi-arrow-repeat"></i></div>
                    </div>
                    <h6 class="fw-bold text-white mt-2">Đổi Trả Dễ Dàng</h6>
                    <small class="text-secondary">1 đổi 1 trong 30 ngày nếu có lỗi phần cứng</small>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card bg-darker border-0 rounded-4 text-center p-4 h-100 shadow-sm hover-lift transition-transform">
                    <div class="bg-dark rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3 shadow" style="width: 70px; height: 70px;">
                        <div class="text-gradient fs-2"><i class="bi bi-headset"></i></div>
                    </div>
                    <h6 class="fw-bold text-white mt-2">Hỗ Trợ 24/7</h6>
                    <small class="text-secondary">Đội ngũ kỹ thuật viên giàu kinh nghiệm trực tuyến</small>
                </div>
            </div>
        </div>
    </div>
</section>

</div>
