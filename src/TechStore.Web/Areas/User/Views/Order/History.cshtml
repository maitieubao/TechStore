@model List<TechStore.Shared.DTOs.OrderDto>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-darker p-4 rounded-4 shadow-sm">
        <h3 class="fw-bold mb-0 text-white"><i class="bi bi-clock-history text-primary me-2"></i>Lịch sử đơn hàng</h3>
        <a asp-area="User" asp-controller="Profile" asp-action="Index" class="btn btn-outline-light px-4 rounded-pill">
            <i class="bi bi-person me-1"></i> Hồ sơ của tôi
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card border-0 bg-darker rounded-4 shadow-sm hover-shadow-lg transition-all">
                        <div class="card-header border-secondary bg-transparent p-4 d-flex justify-content-between align-items-center flex-wrap gap-2 rounded-top-4">
                            <div>
                                <h6 class="fw-bold mb-1 text-white">Đơn hàng <span class="text-info">#@order.Id</span></h6>
                                <small class="text-secondary"><i class="bi bi-calendar-event me-1"></i>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <div class="d-flex flex-wrap gap-2 text-end">
                                @{
                                    var statusClass = order.Status switch
                                    {
                                        "Pending" => "bg-warning text-dark",
                                        "Shipping" => "bg-indigo text-white",
                                        "Delivered" => "bg-success text-white",
                                        "Cancelled" => "bg-danger text-white",
                                        _ => "bg-secondary text-white"
                                    };
                                }
                                <span class="badge @statusClass py-2 px-3 fw-semibold rounded-pill" style="font-size: 0.8rem;">
                                    @(order.Status switch {
                                        "Pending" => "Chờ xác nhận",
                                        "Shipping" => "Đang giao hàng",
                                        "Delivered" => "Hoàn thành",
                                        "Cancelled" => "Đã huỷ",
                                        _ => order.Status 
                                    })
                                </span>
                                
                                @if (!string.IsNullOrEmpty(order.PaymentStatus))
                                {
                                    var payClass = order.PaymentStatus == "Paid" ? "bg-success text-white" : "bg-warning text-dark";
                                    var payIcon = order.PaymentStatus == "Paid" ? "bi-check-circle" : "bi-clock";
                                    <span class="badge @payClass py-2 px-3 fw-semibold rounded-pill" style="font-size: 0.8rem;">
                                        <i class="bi @payIcon me-1"></i>@order.PaymentStatus
                                    </span>
                                }
                            </div>
                        </div>
                        
                        <div class="card-body p-4">
                            <!-- Items preview -->
                            <div class="mb-4">
                                @foreach (var item in order.Items.Take(3))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom border-secondary border-opacity-25 last-border-none">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-dark rounded p-2 flex-shrink-0 border border-secondary" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-box text-secondary fs-5"></i>
                                            </div>
                                            <div>
                                                <small class="fw-semibold text-white d-block mb-1" style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @item.ProductName
                                                </small>
                                                <small class="text-secondary">SL: @item.Quantity</small>
                                            </div>
                                        </div>
                                        <small class="text-secondary">@item.UnitPrice.ToString("N0") ₫</small>
                                    </div>
                                }
                                @if (order.Items.Count > 3)
                                {
                                    <div class="text-center mt-2">
                                        <small class="text-secondary fst-italic">... và @(order.Items.Count - 3) sản phẩm khác</small>
                                    </div>
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center bg-dark p-3 rounded-3 mt-3">
                                <div>
                                    <span class="text-secondary small d-block mb-1">Tổng thành tiền</span>
                                    <span class="text-price fs-5 fw-bold">@((order.TotalAmount - order.DiscountAmount).ToString("N0")) ₫</span>
                                </div>
                                <a asp-controller="Order" asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-light rounded-pill px-4">
                                    Xem chi tiết <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-darker rounded-4 shadow-sm border border-secondary border-opacity-25">
            <div class="d-flex justify-content-center mb-3">
                <div class="bg-dark rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 80px; height: 80px;">
                    <i class="bi bi-bag-x fs-1 text-secondary opacity-50"></i>
                </div>
            </div>
            <h5 class="text-white fw-bold">Bạn chưa có đơn hàng nào</h5>
            <p class="text-secondary mb-4">Hãy khám phá các sản phẩm nổi bật của TechStore nhé!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-gradient btn-lg rounded-pill px-5 shadow">
                <i class="bi bi-cart me-2"></i> Mua sắm ngay
            </a>
        </div>
    }
</div>
