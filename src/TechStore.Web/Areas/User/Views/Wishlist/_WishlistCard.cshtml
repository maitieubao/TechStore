@using TechStore.Shared.DTOs
@model WishlistItemDto

<div class="card h-100 border-0 bg-darker rounded-4 shadow-sm hover-shadow-lg transition-all product-card overflow-hidden group">
    <form asp-controller="Wishlist" asp-action="Remove" asp-route-productId="@Model.ProductId" method="post" class="position-absolute top-0 end-0 m-3 z-3">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-dark bg-opacity-75 border-secondary rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; backdrop-filter: blur(4px);" title="Xóa khỏi yêu thích">
            <i class="bi bi-x-lg text-white"></i>
        </button>
    </form>
    
    <a asp-controller="Product" asp-action="Detail" asp-route-slug="@(Model.ProductSlug ?? Model.ProductId.ToString())" class="text-decoration-none">
        <div class="position-relative overflow-hidden product-img-wrap bg-white d-flex align-items-center justify-content-center p-3" style="aspect-ratio: 1/1;">
            @if (!Model.InStock)
            {
                <span class="badge bg-danger position-absolute top-0 start-0 m-3 z-2 rounded-pill px-3 py-2 shadow-sm">Hết hàng</span>
            }
            <img src="@(Model.ProductImageUrl ?? "/images/no-image.png")" alt="@Model.ProductName" class="img-fluid object-fit-contain transition-transform group-hover-scale" style="max-height: 100%;" />
        </div>
    </a>
    <div class="card-body d-flex flex-column p-4">
        <a asp-controller="Product" asp-action="Detail" asp-route-slug="@(Model.ProductSlug ?? Model.ProductId.ToString())" class="text-decoration-none text-white d-block mb-2">
            <h6 class="card-title text-truncate fw-bold hover-primary transition-colors" title="@Model.ProductName">
                @Model.ProductName
            </h6>
        </a>
        <div class="mt-auto d-flex justify-content-between align-items-center pt-3 border-top border-secondary border-opacity-25">
            <span class="text-price fs-5 fw-bold">@Model.ProductPrice.ToString("N0") ₫</span>
            @if (Model.InStock)
            {
                <form asp-controller="Cart" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <input type="hidden" name="quantity" value="1" />
                    <button type="submit" class="btn btn-gradient rounded-circle d-flex align-items-center justify-content-center shadow-sm hover-lift" style="width: 40px; height: 40px;" title="Thêm vào giỏ">
                        <i class="bi bi-cart-plus fs-5"></i>
                    </button>
                </form>
            }
        </div>
    </div>
</div>
