@using TechStore.Shared.DTOs
@model List<WishlistItemDto>

@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4 bg-darker p-4 rounded-4 shadow-sm">
        <h3 class="fw-bold mb-0 text-white"><i class="bi bi-heart-fill text-danger me-2"></i>Danh sách yêu thích <span class="badge bg-secondary rounded-pill ms-2" style="font-size: 0.9rem;">@Model.Count</span></h3>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-light px-4 rounded-pill">
            <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <partial name="_WishlistCard" model="item" />
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-darker rounded-4 shadow-sm border border-secondary-subtle">
            <div class="d-flex justify-content-center mb-3">
                <div class="bg-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <i class="bi bi-heart text-secondary opacity-50" style="font-size: 3rem;"></i>
                </div>
            </div>
            <h4 class="fw-bold text-white mb-2">Danh sách trống</h4>
            <p class="text-secondary mb-4">Bạn chưa thêm sản phẩm nào vào danh sách yêu thích.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-gradient btn-lg rounded-pill px-5 shadow">
                <i class="bi bi-compass me-2"></i> Khám phá ngay
            </a>
        </div>
    }
</div>
