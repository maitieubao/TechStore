@model List<TechStore.Shared.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">Quản lý danh mục</h1>
    <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i> Thêm mới
    </a>
</div>

<div class="card border-0 bg-darker rounded-4 shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover table-borderless align-middle mb-0">
                <thead style="border-bottom: 2px solid #2d3240;">
                    <tr>
                        <th class="ps-4 py-3">ID</th>
                        <th>Hình ảnh</th>
                        <th>Tên danh mục</th>
                        <th>Số sản phẩm</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var category in Model)
                        {
                            <tr style="border-bottom: 1px solid #2d3240;">
                                <td class="ps-4 py-3 fw-bold text-info">#@category.Id</td>
                                <td>
                                    <div class="bg-white rounded p-1 d-inline-block shadow-sm">
                                        <img src="@(category.ImageUrl ?? "/images/no-image.png")" 
                                             alt="@category.Name" 
                                             class="rounded" 
                                             style="width: 48px; height: 48px; object-fit: cover;" />
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-white mb-1">@category.Name</div>
                                    <div class="small text-secondary" style="max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@category.Description">@category.Description</div>
                                </td>
                                <td>
                                    @if(category.ProductCount > 0)
                                    {
                                        <span class="badge bg-primary rounded-pill py-2 px-3">@category.ProductCount sản phẩm</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill py-2 px-3">0 sản phẩm</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@category.Id" 
                                           class="btn btn-sm btn-outline-info rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@category.Id" method="post" 
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Chưa có danh mục nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>
