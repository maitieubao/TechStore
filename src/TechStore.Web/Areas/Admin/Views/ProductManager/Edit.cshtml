@model TechStore.Web.Models.ViewModels.CreateProductVM
@{
    ViewData["Title"] = "Cập nhật sản phẩm";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-white">Cập nhật sản phẩm</h1>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card border-0 bg-darker">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label text-white">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label text-white">Danh mục <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" class="form-select bg-dark text-white border-secondary" required>
                            <option value="">-- Chọn danh mục --</option>
                            @if (ViewBag.Categories is List<TechStore.Shared.DTOs.CategoryDto> categories)
                            {
                                foreach (var cat in categories)
                                {
                                    <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId ? "selected" : null)">@cat.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Price" class="form-label text-white">Giá (VNĐ) <span class="text-danger">*</span></label>
                        <input asp-for="Price" type="number" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="StockQuantity" class="form-label text-white">Số lượng tồn kho <span class="text-danger">*</span></label>
                        <input asp-for="StockQuantity" type="number" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Brand" class="form-label text-white">Thương hiệu</label>
                        <input asp-for="Brand" class="form-control bg-dark text-white border-secondary" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Specifications" class="form-label text-white">Thông số kĩ thuật</label>
                    <textarea asp-for="Specifications" class="form-control bg-dark text-white border-secondary" rows="3" placeholder="JSON hoặc Văn bản..."></textarea>
                    <span asp-validation-for="Specifications" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label text-white">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <!-- Combo Section -->
                <div class="card bg-dark border-warning mb-4 p-3">
                    <div class="form-check form-switch mb-3">
                        <input asp-for="IsCombo" class="form-check-input" type="checkbox" id="isComboCheck" role="switch" />
                        <label class="form-check-label text-warning fw-semibold" for="isComboCheck">
                            <i class="bi bi-gift me-1"></i> Đây là sản phẩm Deal Combo
                        </label>
                    </div>
                    <div id="comboPriceSection" style="display: @(Model.IsCombo ? "block" : "none");">
                        <label asp-for="OriginalPrice" class="form-label text-secondary small">Giá gốc trước khi giảm (VNĐ)</label>
                        <input asp-for="OriginalPrice" type="number" class="form-control bg-darker text-white border-warning" placeholder="Nhập giá gốc để hiển thị mức tiết kiệm..." />
                        <span asp-validation-for="OriginalPrice" class="text-danger small"></span>
                        <div class="form-text text-secondary mt-1">Giá sale (thực tế) đặt ở ô "Giá (VNĐ)" phía trên.</div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const check = document.getElementById('isComboCheck');
        const section = document.getElementById('comboPriceSection');
        check.addEventListener('change', () => section.style.display = check.checked ? 'block' : 'none');
    </script>
}
