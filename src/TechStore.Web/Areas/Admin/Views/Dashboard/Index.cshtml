@model TechStore.Web.Models.ViewModels.AdminDashboardVM
@{
    ViewData["Title"] = "Quản trị";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h2>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-secondary-subtle text-center p-3">
                <div class="text-gradient fw-bold display-6">@Model.Dashboard.TotalRevenue.ToString("N0")</div>
                <small class="text-secondary">Doanh thu (₫)</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary-subtle text-center p-3">
                <div class="text-gradient fw-bold display-6">@Model.Dashboard.TotalOrders</div>
                <small class="text-secondary">Đơn hàng</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary-subtle text-center p-3">
                <div class="text-gradient fw-bold display-6">@Model.Dashboard.TotalProducts</div>
                <small class="text-secondary">Sản phẩm</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary-subtle text-center p-3">
                <div class="text-gradient fw-bold display-6">@Model.Dashboard.TotalUsers</div>
                <small class="text-secondary">Người dùng</small>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Quick links -->
        <div class="col-md-6">
            <div class="card border-secondary-subtle">
                <div class="card-body">
                    <h5 class="card-title fw-semibold mb-3">Quản lý</h5>
                    <div class="d-grid gap-2">
                        <a asp-area="Admin" asp-controller="OrderManager" asp-action="Index" class="btn btn-outline-light text-start">
                            <i class="bi bi-bag-check me-2"></i> Quản lý đơn hàng
                        </a>
                        <a asp-area="Admin" asp-controller="ProductManager" asp-action="Index" class="btn btn-outline-light text-start">
                            <i class="bi bi-box me-2"></i> Quản lý sản phẩm
                        </a>
                        <a asp-area="Admin" asp-controller="CategoryManager" asp-action="Index" class="btn btn-outline-light text-start mt-2">
                            <i class="bi bi-tags me-2"></i> Quản lý danh mục
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Top products -->
        <div class="col-md-6">
            <div class="card border-secondary-subtle">
                <div class="card-body">
                    <h5 class="card-title fw-semibold mb-3">Top sản phẩm bán chạy</h5>
                    @if (Model.Dashboard.TopSellingProducts?.Any() ?? false)
                    {
                        <ol class="list-group list-group-numbered list-group-flush">
                            @foreach (var p in Model.Dashboard.TopSellingProducts.Take(5))
                            {
                                <li class="list-group-item bg-transparent d-flex justify-content-between">
                                    <span>@p.ProductName</span>
                                    <span class="badge bg-info-subtle text-info">@p.TotalSold đã bán</span>
                                </li>
                            }
                        </ol>
                    }
                    else
                    {
                        <p class="text-secondary small">Chưa có dữ liệu</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
